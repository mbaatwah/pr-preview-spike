# PR preview spike configuration
# Copy this to .env and fill in the values

# ── Required for SSH-remote flow (provision.sh) ──
VPS_IP=
VPS_USER=root
SSH_KEY_PATH=

# ── Required for both flows ──
# Generate webhook secret: openssl rand -hex 32
WEBHOOK_SECRET=your-github-app-webhook-secret

# Base domain for PR previews
BASE_DOMAIN=mypreviews.online

# Smee.io channel (go to https://smee.io, start a channel, paste URL)
SMEE_CHANNEL=https://smee.io/your-channel
